{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Tag Scans Per Minute",
      "description": "Rate of RFID tag scan events per minute, by gate reader and direction",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "opm"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(rfid_tags_total[1m]) * 60",
          "legendFormat": "{{gate_reader_id}} — {{direction}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Events (Success vs Errors)",
      "description": "Cumulative successful and error responses",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rfid_success_total)",
          "legendFormat": "Success (4000)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "title": "Errors",
      "description": "Total error responses by error code",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rfid_errors_total) or vector(0)",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "title": "Health Packets Per Reader",
      "description": "Health status packets received per gate reader",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(rfid_health_packets_total[1m]) * 60",
          "legendFormat": "{{gate_reader_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Antennas Down",
      "description": "Number of antennas currently reporting down per gate reader. Red = antenna failure needs attention.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "min": 0,
          "max": 4
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rfid_antennas_down",
          "legendFormat": "{{gate_reader_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Duration (p95)",
      "description": "95th percentile response time for processing RFID packets",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rfid_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 response time",
          "refId": "A"
        }
      ]
    },
    {
      "title": "IN vs OUT Tag Events",
      "description": "Total tag scans split by direction",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum by (direction) (rfid_tags_total)",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "MQTT Connection",
      "description": "MQTT broker connection status (1=connected, 0=disconnected)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DISCONNECTED", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "CONNECTED", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "mqtt_connected",
          "legendFormat": "MQTT",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "title": "Auth Rejections",
      "description": "Requests rejected due to missing or invalid API key",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(rfid_auth_rejections_total[5m]) * 60",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tags Per Gate Reader",
      "description": "Total tag scans per gate reader",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (gate_reader_id) (rfid_tags_total)",
          "legendFormat": "{{gate_reader_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["rfid", "iot", "middleware"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "RFID Gate Intelligence — Middleware Dashboard",
  "uid": "rfid-middleware-dashboard",
  "version": 1,
  "refresh": "10s"
}